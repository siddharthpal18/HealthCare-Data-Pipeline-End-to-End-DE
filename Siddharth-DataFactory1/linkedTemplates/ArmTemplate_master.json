{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "Siddharth-DataFactory1"
		},
		"AzureDataLakeStorage1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage1'"
		},
		"AzureDataLakeStorage1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlstoragesiddharth.dfs.core.windows.net/"
		},
		"AzureDatabricksLS_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0503-184439-1wmipfhe"
		},
		"AzureKeyVault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://project1db.vault.azure.net/"
		},
		"AzureSynapseArtifacts1_properties_typeProperties_endpoint": {
			"type": "string",
			"defaultValue": "https://siddharth-synapse1.dev.azuresynapse.net"
		},
		"HttpServerGith_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/"
		},
		"HttpServerGith_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "siddharthpal18"
		},
		"HttpServerLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://www.kaggle.com/api/v1/"
		},
		"HttpServerLS_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "siddharthpal121"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "Siddharth-DataFactory1_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage1_accountKey": {
						"value": "[parameters('AzureDataLakeStorage1_accountKey')]"
					},
					"AzureDataLakeStorage1_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage1_properties_typeProperties_url')]"
					},
					"AzureKeyVault_properties_typeProperties_baseUrl": {
						"value": "[parameters('AzureKeyVault_properties_typeProperties_baseUrl')]"
					},
					"AzureSynapseArtifacts1_properties_typeProperties_endpoint": {
						"value": "[parameters('AzureSynapseArtifacts1_properties_typeProperties_endpoint')]"
					},
					"AzureDatabricksLS_properties_typeProperties_existingClusterId": {
						"value": "[parameters('AzureDatabricksLS_properties_typeProperties_existingClusterId')]"
					},
					"HttpServerGith_properties_typeProperties_url": {
						"value": "[parameters('HttpServerGith_properties_typeProperties_url')]"
					},
					"HttpServerGith_properties_typeProperties_userName": {
						"value": "[parameters('HttpServerGith_properties_typeProperties_userName')]"
					},
					"HttpServerLS_properties_typeProperties_url": {
						"value": "[parameters('HttpServerLS_properties_typeProperties_url')]"
					},
					"HttpServerLS_properties_typeProperties_userName": {
						"value": "[parameters('HttpServerLS_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}